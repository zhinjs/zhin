{
  "name": "@zhin.js/example-next-migration-bot",
  "version": "0.0.0",
  "private": true,
  "description": "Executable dual-version tracer for incremental migration to Zhin Next",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "start:next": "zhin-next start",
    "test": "vitest run --root ../.. examples/next-migration-bot/tests"
  },
  "dependencies": {
    "@zhin.js/next-compat": "workspace:*",
    "@zhin.js/next-feature-command": "0.0.0",
    "@zhin.js/next-feature-component": "0.0.0",
    "@zhin.js/next-feature-middleware": "0.0.0",
    "@zhin.js/next-kernel": "workspace:*",
    "@zhin.js/next-runtime": "workspace:*",
    "zhin.js": "workspace:*"
  },
  "devDependencies": {
    "@zhin.js/next-cli": "workspace:*",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "zhin": {
    "protocol": 1,
    "type": "plugin",
    "entry": "./plugin.next.ts",
    "engine": "^1.0.0",
    "runtime": "trusted",
    "features": [
      { "package": "@zhin.js/next-feature-command", "api": "^1.0.0" },
      { "package": "@zhin.js/next-feature-component", "api": "^1.0.0" },
      { "package": "@zhin.js/next-feature-middleware", "api": "^1.0.0" }
    ],
    "plugins": []
  }
}
