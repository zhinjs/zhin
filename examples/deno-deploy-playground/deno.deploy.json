{
  "name": "@zhin/deno-deploy-playground",
  "version": "0.2.0",
  "exports": "./main.ts",
  "tasks": {
    "build:console-assets": "node scripts/build-console-assets.mjs",
    "prepare-deploy": "node scripts/prepare-deploy.mjs",
    "deploy": "deno deploy --prod --config deno.deploy.json main.ts"
  },
  "imports": {
    "zhin.js/deno": "npm:zhin.js@latest/deno",
    "zhin.js": "npm:zhin.js@latest",
    "@zhin.js/core": "npm:@zhin.js/core@latest",
    "@zhin.js/core/": "npm:@zhin.js/core@latest/",
    "@zhin.js/logger": "npm:@zhin.js/logger@latest",
    "@zhin.js/kernel": "npm:@zhin.js/kernel@latest",
    "@zhin.js/schema": "npm:@zhin.js/schema@latest",
    "@zhin.js/database": "npm:@zhin.js/database@latest",
    "@zhin.js/agent": "npm:@zhin.js/agent@latest",
    "@zhin.js/ai": "npm:@zhin.js/ai@latest",
    "@zhin.js/http-host/edge": "npm:@zhin.js/http-host@latest/edge",
    "@zhin.js/http-host": "npm:@zhin.js/http-host@latest",
    "@zhin.js/http/adapter-api-stubs": "npm:@zhin.js/http@latest/adapter-api-stubs",
    "@zhin.js/http/host-rest-api": "npm:@zhin.js/http@latest/host-rest-api",
    "@zhin.js/http/logs-rest-api": "npm:@zhin.js/http@latest/logs-rest-api",
    "@zhin.js/http/marketplace-rest-api": "npm:@zhin.js/http@latest/marketplace-rest-api",
    "@zhin.js/console/console-api": "npm:@zhin.js/console@latest/console-api",
    "@zhin.js/console/rpc/project-fs": "npm:@zhin.js/console@latest/rpc/project-fs",
    "@zhin.js/storage-port": "npm:@zhin.js/storage-port@latest",
    "@zhin.js/queue-runtime": "npm:@zhin.js/queue-runtime@latest",
    "@zhin.js/adapter-sandbox": "npm:@zhin.js/adapter-sandbox@latest",
    "@zhin.js/adapter-sandbox/edge": "npm:@zhin.js/adapter-sandbox@latest/edge",
    "@zhin.js/console-types": "npm:@zhin.js/console-types@latest"
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.ns", "deno.unstable", "dom", "esnext"]
  },
  "nodeModulesDir": "auto",
  "deploy": {
    "org": "zhinjs",
    "app": "zhin-deno-playground",
    "exclude": [
      "node_modules",
      ".deploy-tools",
      "data",
      ".env",
      ".env.*"
    ]
  }
}
