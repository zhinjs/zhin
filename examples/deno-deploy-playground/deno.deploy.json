    "@zhin.js/queue-runtime": "npm:@zhin.js/queue-runtime@0.1.0",
    "@zhin.js/http/host-rest-api": "npm:@zhin.js/http@1.0.76/host-rest-api",
    "@zhin.js/http/logs-rest-api": "npm:@zhin.js/http@1.0.76/logs-rest-api",
    "@zhin.js/http/marketplace-rest-api": "npm:@zhin.js/http@1.0.76/marketplace-rest-api",
