# 由 zhin.config.yml 引用（ConfigLoader 环境变量替换）
HTTP_TOKEN=

# `deno task dev --watch` 子进程 stdin 常非 TTY；设为 1 以启用 process 适配器（终端发 zt/help）
ZHIN_BIND_STDIN=1

# 可选：覆盖 zhin.config.yml 中 sandbox 机器人名
# SANDBOX_BOT_NAME=edge-bot
# SANDBOX_BOT_OWNER=sandbox-user

OPENAI_API_KEY=
OPENAI_BASE_URL=

# 本地可省略（使用 zhin.config.yml 的 sqlite）。Deno Deploy / 生产请用托管 PostgreSQL：
# DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require
# DATABASE_POOL_MAX=5
# HTTP_TRUST_PROXY=1
