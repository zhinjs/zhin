  "type": "module",
  "scripts": {
    "dev": "zhin runtime start",
    "start": "zhin runtime start --mode production --no-watch",
    "daemon": "zhin runtime start --daemon --mode production --no-watch",
    "build": "tsc --noEmit -p tsconfig.runtime.json",
    "stop": "zhin stop"
