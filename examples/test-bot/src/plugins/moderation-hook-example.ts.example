/**
 * 内容审查 hook 示例（未默认启用）
 *
 * 在 zhin.config.yml 的 plugins: 中加入本文件名（去掉 .example 后缀）方可加载。
 * 不含词库 — 仅演示 Guardrail + before.sendMessage 挂载点。
 * 见 docs/advanced/content-moderation.md
 */
import { usePlugin, segment, type SendOptions } from 'zhin.js';

const plugin = usePlugin();

function shouldBlockInbound(text: string): boolean {
  void text;
  return false;
}

plugin.useContext('dispatcher', (dispatcher) => {
  return dispatcher.addGuardrail(async (message, next) => {
    const text = segment.raw(message.$content);
    if (shouldBlockInbound(text)) return;
    await next();
  });
});

const outboundHandler = async (options: SendOptions) => {
  if (!options.content) return options;
  const text =
    typeof options.content === 'string'
      ? options.content
      : segment.toString(options.content);
  void text;
  return options;
};

plugin.on('before.sendMessage', outboundHandler);
plugin.onDispose(() => plugin.off('before.sendMessage', outboundHandler));
