# ICQQ_LOGIN_UIN
ICQQ_LOGIN_UIN=147258369

# 日志配置
LOG_LEVEL=info
DEBUG=false

# 环境配置
NODE_ENV=development

# HTTP / Remote Console（GitHub Pages UI 连本地 API 时必填）
# HTTP_TOKEN=your-secret-token
# 并在 zhin.config 中设置 http.corsOrigins 包含 Pages 源（见 docs/console-remote.md）

# 智谱开放平台 BigModel（zhin.config → ai.providers.zhipu-vl）
# https://open.bigmodel.cn/usercenter/apikeys
# 文生图免费默认：cogview-3-flash（Flash 系列）；cogview-4 等按次付费（约 0.06 元/次）
# BIG_MODEL_API_KEY=your-bigmodel-api-key

# Cloudflare Workers AI（zhin.config → ai.providers.cloudflare-flash）
# Token：Dashboard → Workers AI → Use REST API → Create API Token
# Account ID：同页「Get Account ID」
# CLOUDFLARE_API_TOKEN=your-workers-ai-api-token
# CLOUDFLARE_ACCOUNT_ID=your-account-id

# MCP server-github（启用 @zhin.js/adapter-github 时）
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxxxxxxxxxxx

# OpenAI 兼容（ai.providers.openai-main，agents.zhin.model）
# 也可用于文生图：取消注释 zhin.config 中 openai-image（gpt-image-2，按量计费）
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini / Nano Banana（取消注释 zhin.config 中 gemini-image）
# https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-api-key

# DeepSeek（ai.providers.deepseek-main，可改 agents.zhin.provider 为 deepseek-main）
# DEEP_SEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Home Assistant（assistant.home，M4）
# HA_URL=http://homeassistant.local:8123
# HA_TOKEN=eyJhbGciOi...

# icqq 多 Bot 协作：群内 master 发送 /collab init，再用 /collab bind <endpoint> <pipelineRole> 挂载各 Bot
# Five-Agent 需齐 5 个账号；缺任一会在启动日志出现 Endpoint skip/failed
# ICQQ_ACCOUNT=8596238
# ICQQ_ACCOUNT_2=210723495
# ICQQ_ACCOUNT_3=1689919782
# ICQQ_ACCOUNT_4=329158210
# ICQQ_ACCOUNT_5=717505091

# icqq 守护进程 MCP（ai.agents.zhin.mcpServers: [icqq]）
# 建议固定端口：icqq config set mcp.http.port 58705 && icqq service restart
