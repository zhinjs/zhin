# ICQQ_LOGIN_UIN
ICQQ_LOGIN_UIN=147258369

# 日志配置
LOG_LEVEL=info
DEBUG=false

# 环境配置
NODE_ENV=development

# HTTP / Remote Console（GitHub Pages UI 连本地 API 时必填）
# HTTP_TOKEN=your-secret-token
# 并在 zhin.config 中设置 http.corsOrigins 包含 Pages 源（见 docs/console-remote.md）

# 智谱开放平台 BigModel（zhin.config 中 defaultProvider: zhipu）
# https://open.bigmodel.cn/usercenter/apikeys
# BIG_MODEL_API_KEY=your-bigmodel-api-key

# Cloudflare Workers AI（备用：zhin.config 中 defaultProvider: cloudflare）
# Token：Dashboard → Workers AI → Use REST API → Create API Token
# Account ID：同页「Get Account ID」
# CLOUDFLARE_API_TOKEN=your-workers-ai-api-token
# CLOUDFLARE_ACCOUNT_ID=your-account-id

# MCP server-github（启用 @zhin.js/adapter-github 时）
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxxxxxxxxxxx

# icqq 守护进程 MCP（icqq service status 查看 URL；icqq config get mcp 查看 token）
# 建议固定端口：icqq config set mcp.http.port 58705 && icqq service restart
