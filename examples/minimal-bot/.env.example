# Web 控制台 / HTTP API（与 zhin.config 中 http.token 一致）
HTTP_TOKEN=minimal-dev-token

# 可选：OpenAI 兼容 API（在 zhin.config 增加 providers.openai + agents.zhin.provider）
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# 默认：本地 Ollama（ai.providers.ollama.driver + agents.zhin.model）
# 需先 ollama serve，并 pull agents.zhin.model 所列模型（如 qwen3:8b）
