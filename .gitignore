vendor/
*.swp
*.swo
*~

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.test

# TypeScript cache
*.tsbuildinfo

# Accidental root-level tsc emit (normal builds use per-package outDir lib/)
**/src/**/*.js
**/src/**/*.js.map
**/src/**/*.d.ts.map
**/tests/**/*.js
**/tests/**/*.js.map
**/tests/**/*.d.ts
**/tests/**/*.d.ts.map

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn v2
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# Test directory - ignore config files and env files
test/.env*
test/zhin.config.*
test/config.*
!test/env.example

# Apps directory - ignore config files and env files
apps/**/.env*
apps/**/zhin.config.*
apps/**/config.*
!apps/**/env.example 

**/dist/**

# Heap snapshots (large binary, never commit)
*.heapsnapshot
# Generated API reference (run pnpm docs:api)
docs/api/
