# Dependencies
node_modules/
.pnpm-store/
.agent/
.agents/
.claude/
/data/
# schedule 包内置节假日/农历数据源（须入库，否则 CI tsc 缺文件）
!basic/schedule/src/data/
!basic/schedule/src/data/**
.cursor/
.opencode/
.codex/
.pnp
.pnp.js
test-bot/data
docs/.vitepress/cache
docs/.vitepress/dist
# Testing
coverage/
/tests/.tmp/

# Turbo
.turbo/
# Production builds
lib/
# test-bot lib/ 存放共享 TS 源码（commands/tools 引用）；其编译产物由 examples/test-bot/.gitignore 忽略
!examples/test-bot/lib/
build/
examples/**/data/
examples/**/zhin.config.*
!examples/minimal-bot/zhin.config.yml
!examples/full-bot/zhin.config.yml
!examples/demo-bot/zhin.config.yml
!examples/life-assistant-bot/zhin.config.yml
!examples/multi-agent-room/zhin.config.yml
# full-bot L4 种子 MEMORY（其余 data/ 仍忽略）
!examples/full-bot/data/
examples/full-bot/data/*
!examples/full-bot/data/memory/
examples/full-bot/data/memory/*
!examples/full-bot/data/memory/global/
examples/full-bot/data/memory/global/*
!examples/full-bot/data/memory/global/MEMORY.md
# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE
.vscode/
.idea/
.codegraph/

