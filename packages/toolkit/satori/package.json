{
  "name": "@zhin.js/satori",
  "version": "0.2.15",
  "type": "module",
  "description": "HTML/CSS to SVG via official satori, with HTML input support and built-in fonts.",
  "module": "./lib/index.js",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "license": "MPL-2.0",
  "files": [
    "lib/**",
    "fonts/**",
    "NOTICE",
    "LICENSE"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./lib/index.js",
      "types": "./lib/index.d.ts"
    },
    "./jsx-runtime": {
      "import": "./lib/jsx-runtime.js",
      "types": "./lib/jsx-runtime.d.ts"
    },
    "./jsx-dev-runtime": {
      "import": "./lib/jsx-dev-runtime.js",
      "types": "./lib/jsx-dev-runtime.d.ts"
    }
  },
  "scripts": {
    "fetch-noto-cjk": "node scripts/fetch-noto-cjk.mjs",
    "clean": "rimraf lib",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --config vitest.config.ts",
    "test-type": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "ci-check": "pnpm test-type && pnpm test && pnpm lint"
  },
  "keywords": [
    "satori",
    "html",
    "svg",
    "og-image",
    "zhin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhinjs/zhin.git",
    "directory": "packages/toolkit/satori"
  },
  "dependencies": {
    "html-react-parser": "^6.1.3",
    "react": "^19.2.7",
    "satori": "^0.12.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  },
  "author": {
    "name": "lc-cn",
    "email": "admin@liucl.cn",
    "url": "https://github.com/lc-cn"
  }
}
