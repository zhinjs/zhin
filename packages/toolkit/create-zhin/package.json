    "@types/inquirer": "^9.0.7",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "keywords": [
    "zhin",
    "bot",
    "create",
    "scaffold",
    "template"
  ],
