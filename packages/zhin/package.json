{
  "name": "zhin.js",
  "version": "1.0.84",
  "description": "开箱即用的机器人框架 - 包含进程适配器、HTTP服务、Web控制台和SQLite数据库",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "development": "./src/index.ts",
      "import": "./lib/index.js"
    },
    "./jsx": {
      "types": "./lib/jsx.d.ts",
      "development": "./src/jsx.ts",
      "import": "./lib/jsx.js"
    },
    "./jsx-runtime": {
      "types": "./lib/jsx-runtime.d.ts",
      "development": "./src/jsx-runtime.ts",
      "import": "./lib/jsx-runtime.js"
    },
    "./node": {
      "types": "./lib/node.d.ts",
      "development": "./src/node.ts",
      "import": "./lib/node.js"
    },
    "./jsx-dev-runtime": {
      "types": "./lib/jsx-dev-runtime.d.ts",
      "development": "./src/jsx-dev-runtime.ts",
      "import": "./lib/jsx-dev-runtime.js"
    }
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "rimraf lib && tsc",
    "clean": "rimraf lib"
  },
  "dependencies": {
    "@zhin.js/adapter-sandbox": "workspace:*",
    "@zhin.js/agent": "workspace:*",
    "@zhin.js/ai": "workspace:*",
    "@zhin.js/console": "workspace:*",
    "@zhin.js/core": "workspace:*",
    "@zhin.js/http": "workspace:*",
    "@zhin.js/http-host": "workspace:*",
    "@zhin.js/kernel": "workspace:*",
    "@zhin.js/logger": "workspace:*",
    "@zhin.js/queue-runtime": "workspace:*",
    "@zhin.js/schema": "workspace:*",
    "@zhin.js/storage-port": "workspace:*",
    "yaml": "^2.9.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^25.9.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhinjs/zhin.git",
    "directory": "packages/zhin"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
