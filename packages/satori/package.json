{
  "name": "@zhin.js/satori",
  "version": "0.2.1",
  "type": "module",
  "description": "HTML/CSS to SVG via official satori, with HTML input support and built-in fonts.",
  "module": "./lib/index.js",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "license": "MPL-2.0",
  "files": [
    "lib/**",
    "fonts/**",
    "NOTICE",
    "LICENSE"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./lib/index.js",
      "types": "./lib/index.d.ts"
    }
  },
  "scripts": {
    "fetch-noto-cjk": "node scripts/fetch-noto-cjk.mjs",
    "clean": "rimraf lib",
    "build": "tsup",
    "dev": "tsup --watch",
    "test-type": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "ci-check": "pnpm test-type && pnpm lint"
  },
  "keywords": [
    "satori",
    "html",
    "svg",
    "og-image",
    "zhin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhinjs/zhin.git",
    "directory": "packages/satori"
  },
  "dependencies": {
    "html-react-parser": "^5.1.18",
    "react": "^18.3.1 || ^19.0.0",
    "satori": "^0.12.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
