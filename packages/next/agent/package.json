{
  "name": "@zhin.js/next-agent",
  "version": "0.0.0",
  "description": "Snapshot-coherent Agent capability ingress for the next Zhin runtime",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "development": "./src/index.ts",
      "import": "./lib/index.js"
    }
  },
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf lib",
    "test": "vitest run --root ../../.. packages/next/agent/tests",
    "check:size": "node ../runtime/scripts/check-install-size.mjs @zhin.js/next-agent"
  },
  "dependencies": {
    "@zhin.js/next-feature-agent": "workspace:*",
    "@zhin.js/next-feature-mcp": "workspace:*",
    "@zhin.js/next-feature-skill": "workspace:*",
    "@zhin.js/next-feature-tool": "workspace:*",
    "@zhin.js/plugin-runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "license": "MIT",
  "private": true
}
