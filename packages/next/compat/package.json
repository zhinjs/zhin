{
  "name": "@zhin.js/next-compat",
  "version": "0.0.0",
  "description": "Explicit legacy callback adapters for incremental Zhin Next migration",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "development": "./src/index.ts",
      "import": "./lib/index.js"
    }
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf lib",
    "test": "vitest run --root ../../.. packages/next/compat/tests",
    "check:size": "node ../runtime/scripts/check-install-size.mjs @zhin.js/next-compat"
  },
  "dependencies": {
    "@zhin.js/command": "workspace:*",
    "@zhin.js/middleware": "workspace:*"
  },
  "devDependencies": {
    "@zhin.js/plugin-runtime": "workspace:*",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "license": "MIT",
  "private": true
}
