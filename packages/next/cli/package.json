{
  "name": "@zhin.js/next-cli",
  "version": "0.0.0",
  "description": "Project graph tooling for greenfield Zhin Plugin monorepos",
  "type": "module",
  "bin": {
    "zhin-next": "./lib/bin.js"
  },
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "development": "./src/index.ts",
      "import": "./lib/index.js"
    },
    "./migrate": {
      "types": "./lib/migrate/index.d.ts",
      "development": "./src/migrate/index.ts",
      "import": "./lib/migrate/index.js"
    }
  },
  "files": ["lib"],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf lib",
    "test": "vitest run --root ../../.. packages/next/cli/tests",
    "check:api": "node ../scripts/check-api-surface.mjs",
    "check:size": "node ../runtime/scripts/check-install-size.mjs @zhin.js/next-cli"
  },
  "dependencies": {
    "@zhin.js/next-runtime": "workspace:*"
  },
  "peerDependencies": {
    "typescript": ">=5.8.0 <7.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@zhin.js/next-compat": "workspace:*",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "license": "MIT",
  "private": true
}
