{
  "name": "@zhin.js/next-config-yaml",
  "version": "0.0.0",
  "description": "Comment-preserving YAML ConfigDocument adapter for the next Zhin runtime",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "development": "./src/index.ts",
      "import": "./lib/index.js"
    }
  },
  "files": ["lib"],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf lib",
    "test": "vitest run --root ../../.. packages/next/config-yaml/tests",
    "check:size": "node ../runtime/scripts/check-install-size.mjs @zhin.js/next-config-yaml"
  },
  "dependencies": {
    "@zhin.js/next-runtime": "workspace:*",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@zhin.js/next-kernel": "workspace:*",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "license": "MIT",
  "private": true
}
