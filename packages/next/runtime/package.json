{
  "name": "@zhin.js/next-runtime",
  "version": "0.0.0",
  "description": "Static package graph and Root runtime for the greenfield Zhin architecture",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "development": "./src/index.ts",
      "import": "./lib/index.js"
    }
  },
  "files": ["lib"],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf lib",
    "test": "vitest run --root ../../.. packages/next/runtime/tests",
    "check:size": "node ./scripts/check-install-size.mjs"
  },
  "dependencies": {
    "@zhin.js/next-feature-kit": "workspace:*",
    "@zhin.js/next-kernel": "workspace:*",
    "ajv": "8.18.0",
    "semver": "7.8.5"
  },
  "devDependencies": {
    "@zhin.js/next-feature-command": "workspace:*",
    "@zhin.js/next-feature-component": "workspace:*",
    "@zhin.js/next-feature-agent": "workspace:*",
    "@zhin.js/next-feature-mcp": "workspace:*",
    "@zhin.js/next-feature-middleware": "workspace:*",
    "@zhin.js/next-feature-layout": "workspace:*",
    "@zhin.js/next-feature-page": "workspace:*",
    "@zhin.js/next-feature-skill": "workspace:*",
    "@zhin.js/next-feature-tool": "workspace:*",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "license": "MIT",
  "private": true
}
