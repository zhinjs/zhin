{
  "name": "@zhin.js/next-runtime",
  "version": "0.0.0",
  "description": "Static package graph and Root runtime for the greenfield Zhin architecture",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "development": "./src/index.ts",
      "import": "./lib/index.js"
    }
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf lib",
    "test": "vitest run --root ../../.. packages/next/runtime/tests",
    "check:size": "node ./scripts/check-install-size.mjs"
  },
  "dependencies": {
    "@zhin.js/feature-kit": "workspace:*",
    "@zhin.js/plugin-runtime": "workspace:*",
    "ajv": "8.18.0",
    "semver": "7.8.5"
  },
  "devDependencies": {
    "@zhin.js/adapter": "workspace:*",
    "@zhin.js/command": "workspace:*",
    "@zhin.js/component": "workspace:*",
    "@zhin.js/middleware": "workspace:*",
    "@zhin.js/agent-feature": "workspace:*",
    "@zhin.js/mcp-feature": "workspace:*",
    "@zhin.js/layout": "workspace:*",
    "@zhin.js/page": "workspace:*",
    "@zhin.js/skill": "workspace:*",
    "@zhin.js/tool": "workspace:*",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "license": "MIT",
  "private": true
}
