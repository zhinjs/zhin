    "clean": "rimraf lib",
    "test": "vitest run --root ../../.. packages/next/client-build/tests"
  },
  "peerDependencies": {
    "@zhin.js/next-console-contract": "*",
    "@zhin.js/feature-kit": "*",
    "@zhin.js/plugin-runtime": "*",
    "@zhin.js/next-runtime": "*",
    "typescript": ">=5.8.0 <7.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "license": "MIT",
  "private": true
}
