{
  "name": "@zhin.js/next-client-build",
  "version": "0.0.0",
  "description": "Optional TypeScript AST and manifest adapter for Zhin Next client modules",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "development": "./src/index.ts",
      "import": "./lib/index.js"
    }
  },
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
