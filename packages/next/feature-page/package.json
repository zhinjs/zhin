{
  "name": "@zhin.js/next-feature-page",
  "version": "0.0.0",
  "description": "Convention Page manifest Feature for Zhin Next",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "development": "./src/index.ts",
