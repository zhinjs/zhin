{
  "name": "@zhin.js/bridge-inbound-glue",
  "version": "0.0.1",
  "description": "Bridge v1 inbound chain glue: IM dispatch / K1 / L1 / bridgeStatus + optional circuit restart",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "development": "./src/index.ts",
      "import": "./lib/index.js"
    }
