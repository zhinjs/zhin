{
  "name": "@zhin.js/console-core",
  "version": "1.0.0",
  "description": "Zhin console Host runtime: PageManager + esbuild pipeline for adapter entries (no UI)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    },
    "./node": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.server.json",
    "build:node": "tsc -p tsconfig.server.json",
    "typecheck": "tsc -p tsconfig.server.json --noEmit",
    "clean": "rimraf dist lib"
  },
  "dependencies": {
    "@koa/router": "^15.5.0",
    "@zhin.js/console-types": "workspace:*",
    "esbuild": "^0.28.0",
    "koa": "^2.16.2",
    "koa-compose": "^4.1.0",
    "koa-static": "^5.0.0"
  },
  "devDependencies": {
    "@types/koa": "^2.15.0",
    "@types/koa-compose": "^3.2.9",
    "@types/koa-static": "^4.0.4",
    "@types/koa__router": "^12.0.4",
    "@types/node": "^25.8.0",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.2"
  },
  "files": [
    "lib"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhinjs/zhin.git",
    "directory": "packages/console-core"
  }
}
