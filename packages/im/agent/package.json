  "files": [
    "lib"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf lib"
  },
  "dependencies": {
    "@a2a-js/sdk": "1.0.0-beta.0",
    "@zhin.js/ai": "workspace:*",
    "@zhin.js/core": "workspace:*",
    "@zhin.js/kernel": "workspace:*",
    "@zhin.js/schedule": "workspace:*",
    "@zhin.js/logger": "workspace:*",
    "he": "^1.2.0",
    "js-yaml": "^5.2.1"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/he": "^1.2.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.0",
    "rimraf": "^6.0.0",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhinjs/zhin.git",
    "directory": "packages/im/agent"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "license": "MIT",
  "author": {
    "name": "lc-cn",
    "email": "admin@liucl.cn",
