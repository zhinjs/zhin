{
  "name": "@zhin.js/agent",
  "version": "0.3.0",
  "description": "Zhin AI Agent — session, ZhinAgent, init; composes @zhin.js/core providers and tools",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "development": "./src/index.ts",
      "import": "./lib/index.js"
    },
    "./config": {
      "types": "./lib/config/index.d.ts",
      "development": "./src/config/index.ts",
      "import": "./lib/config/index.js"
    },
    "./task-executor": {
      "types": "./lib/task-executor.d.ts",
      "development": "./src/task-executor.ts",
      "import": "./lib/task-executor.js"
    }
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf lib"
  },
  "dependencies": {
    "@zhin.js/ai": "workspace:*",
    "@zhin.js/core": "workspace:*",
    "@zhin.js/logger": "workspace:*",
    "he": "^1.2.0",
    "zod": "^4.4.3",
    "js-yaml": "^4.2.0"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/he": "^1.2.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.3",
    "rimraf": "^6.0.0",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhinjs/zhin.git",
    "directory": "packages/im/agent"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
