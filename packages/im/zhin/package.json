{
  "name": "zhin.js",
  "version": "4.0.1",
  "description": "Zhin.js IM 核心（<10MB 安装预算）；AI 请另装 @zhin.js/agent",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "development": "./src/index.ts",
      "import": "./lib/index.js"
    },
    "./agent": {
      "types": "./lib/agent.d.ts",
      "development": "./src/agent.ts",
      "import": "./lib/agent.js"
    },
    "./ai": {
      "types": "./lib/ai.d.ts",
      "development": "./src/ai.ts",
      "import": "./lib/ai.js"
    },
    "./jsx": {
      "types": "./lib/jsx.d.ts",
      "development": "./src/jsx.ts",
      "import": "./lib/jsx.js"
    },
    "./jsx-runtime": {
      "types": "./lib/jsx-runtime.d.ts",
      "development": "./src/jsx-runtime.ts",
      "import": "./lib/jsx-runtime.js"
    },
    "./node": {
      "types": "./lib/node.d.ts",
      "development": "./src/node.ts",
      "import": "./lib/node.js"
    },
    "./jsx-dev-runtime": {
      "types": "./lib/jsx-dev-runtime.d.ts",
      "development": "./src/jsx-dev-runtime.ts",
      "import": "./lib/jsx-dev-runtime.js"
    },
    "./contexts": {
      "types": "./lib/zhin-contexts.d.ts",
      "development": "./zhin-contexts.d.ts"
    }
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "rimraf lib && tsc && cp zhin-contexts.d.ts lib/zhin-contexts.d.ts",
    "clean": "rimraf lib"
  },
  "dependencies": {
    "@zhin.js/core": "workspace:*",
    "@zhin.js/kernel": "workspace:*",
    "@zhin.js/logger": "workspace:*",
    "@zhin.js/schema": "workspace:*",
    "yaml": "^2.9.0",
    "dotenv": "^17.4.2"
  },
  "peerDependencies": {
    "@zhin.js/agent": "^0.3.1",
    "@zhin.js/host-api": "workspace:^",
    "@zhin.js/host-router": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@zhin.js/agent": {
      "optional": true
    },
    "@zhin.js/host-api": {
      "optional": true
    },
    "@zhin.js/host-router": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@zhin.js/agent": "workspace:*",
    "@zhin.js/ai": "workspace:*",
    "@zhin.js/host-api": "workspace:*",
    "@zhin.js/host-router": "workspace:*",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhinjs/zhin.git",
    "directory": "packages/im/zhin"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "license": "MIT",
  "author": {
    "name": "lc-cn",
    "email": "admin@liucl.cn",
    "url": "https://github.com/lc-cn"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
