      "import": "./lib/agent-step-checkpoint.js"
    },
    "./tool-policy": {
      "types": "./lib/tool-policy.d.ts",
      "development": "./src/tool-policy.ts",
      "import": "./lib/tool-policy.js"
    },
    "./mcp-qualified-name": {
      "types": "./lib/mcp-qualified-name.d.ts",
      "development": "./src/mcp-qualified-name.ts",
      "import": "./lib/mcp-qualified-name.js"
    },
    "./authorization-events": {
      "types": "./lib/authorization-events.d.ts",
      "development": "./src/authorization-events.ts",
      "import": "./lib/authorization-events.js"
