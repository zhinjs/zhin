{
  "name": "@zhin.js/kernel",
  "version": "0.0.11",
  "description": "Framework-agnostic runtime kernel: Plugin DI, Feature, Config, Cron, Scheduler, errors, utilities",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "development": "./src/index.ts",
      "import": "./lib/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf lib",
    "test": "vitest run --config ../../vitest.config.ts"
  },
  "dependencies": {
    "@zhin.js/logger": "workspace:*",
    "@zhin.js/schema": "workspace:*",
    "croner": "^9.1.0",
    "yaml": "^2.3.4",
    "smol-toml": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhinjs/zhin.git",
    "directory": "packages/kernel"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
