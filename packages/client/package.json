{
  "name": "@zhin.js/client",
  "version": "1.0.18",
  "description": "Zhin console client: app singleton + WebSocket + re-exports (aligned with page-manager)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@zhin.js/console-core": "workspace:*",
    "@zhin.js/console-types": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "files": [
    "dist",
    "client"
  ],
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.1",
    "react": "^19.2.5",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhinjs/zhin.git",
    "directory": "packages/client"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
