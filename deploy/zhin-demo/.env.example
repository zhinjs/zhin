# 复制为 .env 后填入生产密钥（勿提交）

ADMIN_TOKEN=
DEMO_TOKEN=

# 构建 Demo Console 时注入（CI secrets）
VITE_API_BASE=https://demo-api.zhin.dev
VITE_API_TOKEN=${DEMO_TOKEN}

# Ollama 模型（与 demo-bot zhin.config 一致）
OLLAMA_MODEL=qwen3:8b

# 可选：Cloudflare Origin 证书路径（挂载到 nginx）
# SSL_CERT=/etc/nginx/certs/origin.pem
# SSL_KEY=/etc/nginx/certs/origin-key.pem
