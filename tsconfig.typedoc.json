{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "types": ["node"],
    "outDir": "./docs/api-void",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@zhin.js/logger": ["./basic/logger/src/index.ts"],
      "@zhin.js/schema": ["./basic/schema/src/index.ts"],
      "@zhin.js/database": ["./basic/database/src/index.ts"],
      "@zhin.js/schedule": ["./basic/schedule/src/index.ts"],
      "@zhin.js/kernel": ["./packages/im/kernel/src/index.ts"],
      "@zhin.js/ai": ["./packages/im/ai/src/index.ts"],
      "@zhin.js/ai/agent-stream": ["./packages/im/ai/src/agent-stream.ts"],
      "@zhin.js/ai/agent-stream-consumer": ["./packages/im/ai/src/agent-stream-consumer.ts"],
      "@zhin.js/ai/agent-step-checkpoint": ["./packages/im/ai/src/agent-step-checkpoint.ts"],
      "@zhin.js/ai/tool-policy": ["./packages/im/ai/src/tool-policy.ts"],
      "@zhin.js/ai/mcp-qualified-name": ["./packages/im/ai/src/mcp-qualified-name.ts"],
      "@zhin.js/ai/authorization-events": ["./packages/im/ai/src/authorization-events.ts"],
      "@zhin.js/core": ["./packages/im/core/src/index.ts"],
      "@zhin.js/core/queue-im-field-contract": ["./packages/im/core/src/built/queue-im-field-contract.ts"],
      "@zhin.js/agent": ["./packages/im/agent/src/index.ts"],
      "@zhin.js/cli": ["./basic/cli/src/index.ts"]
    }
  },
  "include": [
    "packages/im/ai/src/**/*.ts",
    "packages/im/core/src/**/*.ts",
    "packages/im/agent/src/**/*.ts",
    "packages/im/kernel/src/**/*.ts",
    "basic/logger/src/**/*.ts",
    "basic/schema/src/**/*.ts",
    "basic/database/src/**/*.ts",
    "basic/schedule/src/**/*.ts"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/lib/**",
    "**/tests/**",
    "**/*.test.ts",
    "**/dist/**"
  ]
}
