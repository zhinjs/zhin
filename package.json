{
  "name": "zhin-next",
  "version": "1.0.0",
  "description": "TypeScript机器人框架",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "workspaces": [
    "basic/*",
    "packages/*",
    "plugins/adapters/*",
    "plugins/services/*",
    "plugins/features/*",
    "plugins/games/*",
    "plugins/utils/*",
    "examples/*",
    "docs"
  ],
  "packageManager": "pnpm@9.0.2",
  "scripts": {
    "dev": "pnpm --filter test-bot dev",
    "start": "pnpm --filter test-bot start",
    "daemon": "pnpm --filter test-bot daemon",
    "exp:dep": "pnpm --filter dependency-example dev",
    "release": "pnpm changeset",
    "bump": "pnpm changeset version",
    "pub": "pnpm changeset publish",
    "init-publish": "node scripts/init-new-packages.mjs",
    "stop": "pnpm --filter test-bot stop",
    "init": "pnpm --filter test-bot initial && pnpm install",
    "prepare:logger": "pnpm --filter @zhin.js/logger build && pnpm --filter @zhin.js/cli install",
    "prepare:cli": "pnpm --filter @zhin.js/cli build && pnpm install",
    "build": "pnpm -r --filter \"./basic/**\" build && pnpm -r --filter \"./packages/**\" build && pnpm -r --filter \"./plugins/services/**\" build && pnpm -r --filter \"./plugins/adapters/**\" build && pnpm -r --filter \"./plugins/games/**\" build && pnpm -r --filter \"./plugins/utils/**\" build",
    "clean": "pnpm -r clean",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "link": "pnpm --filter @zhin.js/cli exec npm link",
    "test": "vitest run",
    "test:reporter": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "create": "node packages/create-zhin/lib/index.js",
    "docs:dev": "pnpm --filter @zhin.js/docs dev",
    "docs:build": "pnpm --filter @zhin.js/docs build",
    "docs:preview": "pnpm --filter @zhin.js/docs preview",
    "check:prod": "node scripts/check-production-config.js",
    "check:plugin": "node scripts/check-plugin-spec.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^24.10.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.9",
    "eslint": "^9.39.1",
    "rimraf": "^6.1.2",
    "typescript": "^6.0.3",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "cross-spawn": "^7.0.6",
    "fs-extra": "^11.3.2",
    "inquirer": "^12.10.0",
    "ora": "^8.2.0"
  },
  "pnpm": {
    "overrides": {
      "zhin.js": "workspace:*",
      "@zhin.js/core": "workspace:*",
      "@zhin.js/kernel": "workspace:*",
      "@zhin.js/ai": "workspace:*",
      "@zhin.js/logger": "workspace:*",
      "@zhin.js/schema": "workspace:*",
      "@zhin.js/database": "workspace:*",
      "@zhin.js/cli": "workspace:*",
      "@zhin.js/client": "workspace:*",
      "@zhin.js/agent": "workspace:*",
      "@zhin.js/satori": "workspace:*",
      "semver@<5.7.2": ">=5.7.2",
      "esbuild@<=0.24.2": ">=0.25.0",
      "react-router@>=7.0 <7.12.0": ">=7.12.0",
      "axios@>=1.0.0 <1.15.0": ">=1.15.0",
      "vite@>=7.1.0 <=7.3.1": ">=7.3.2",
      "vite@>=8.0.0 <=8.0.4": ">=8.0.5",
      "tar@<=7.5.10": ">=7.5.11",
      "js-yaml@<3.14.2": ">=3.14.2",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "nodemailer@<7.0.7": ">=7.0.7",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "body-parser@>=2.2.0 <2.2.1": ">=2.2.1",
      "nodemailer@<=7.0.10": ">=7.0.11",
      "mdast-util-to-hast@>=13.0.0 <13.2.1": ">=13.2.1",
      "@modelcontextprotocol/sdk@<1.25.2": ">=1.25.2",
      "jws@<3.2.3": ">=3.2.3",
      "nodemailer@<7.0.11": ">=7.0.11",
      "qs@>=6.7.0 <=6.14.1": ">=6.14.2",
      "preact@>=10.28.0 <10.28.2": ">=10.28.2",
      "fast-xml-parser@>=4.3.6 <5.3.8": ">=5.3.8",
      "@isaacs/brace-expansion@<=5.0.0": ">=5.0.1",
      "minimatch@<3.1.4": ">=3.1.4",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@>=10.0.0 <10.2.3": "10.2.4",
      "minimatch@10.2.0": "10.2.4",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "hono@<4.12.7": ">=4.12.7",
      "@hono/node-server@<1.19.10": ">=1.19.10",
      "express-rate-limit@>=8.2.0 <8.2.2": ">=8.2.2",
      "flatted@<3.4.0": ">=3.4.0",
      "undici@<6.24.0": ">=6.24.0",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "ajv@<6.14.0": ">=6.14.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": "8.18.0",
      "dompurify@>=3.1.3 <=3.3.1": ">=3.3.2",
      "koa@>=3.0.0 <3.1.2": ">=3.1.2",
      "@tootallnate/once@<3.0.1": ">=3.0.1"
    }
  }
}
