{
  "name": "zhin",
  "version": "1.0.0",
  "description": "TypeScript机器人框架",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "workspaces": [
    "basic/*",
    "packages/im/*",
    "packages/console/*",
    "packages/toolkit/*",
    "packages/host/*",
    "plugins/adapters/*",
    "plugins/features/*",
    "plugins/utils/*",
    "examples/*",
    "docs"
  ],
  "packageManager": "pnpm@9.0.2",
  "scripts": {
    "dev": "pnpm --filter test-bot dev",
    "start": "pnpm --filter test-bot start",
    "daemon": "pnpm --filter test-bot daemon",
    "exp:dep": "pnpm --filter dependency-example dev",
    "release": "pnpm changeset",
    "bump": "pnpm changeset version",
    "pub": "pnpm changeset publish",
    "init-publish": "node scripts/init-new-packages.mjs",
    "stop": "pnpm --filter test-bot stop",
    "init": "pnpm --filter test-bot initial && pnpm install",
    "prepare:logger": "pnpm --filter @zhin.js/logger build && pnpm --filter @zhin.js/cli install",
    "prepare:cli": "pnpm --filter @zhin.js/scaffold-wizard build && pnpm --filter @zhin.js/cli build && pnpm install",
    "build": "turbo run build --filter=./basic/** --filter=./packages/** --filter=./plugins/**",
    "build:all": "turbo run build",
    "build:force": "turbo run build --filter=./basic/** --filter=./packages/** --filter=./plugins/** --filter=./docs --force",
    "clean": "turbo run clean && rimraf node_modules/.cache/turbo",
    "lint": "eslint .",
    "lint:ci": "eslint . --quiet",
    "check:harness-paths": "node scripts/check-im-send-bypass.mjs",
    "check:no-koa": "node scripts/check-no-koa-imports.mjs",
    "check:architecture": "node scripts/check-architecture-layers.mjs",
    "check:im-session-ssot": "node scripts/check-im-session-ssot.mjs",
    "check:get-model-imports": "node scripts/check-get-model-imports.mjs",
    "check:legacy-ai-exports": "node scripts/check-legacy-ai-exports.mjs",
    "check:doc-links": "node scripts/check-doc-links.mjs",
    "check:install-tiers-ssot": "node scripts/check-install-tiers-ssot.mjs",
    "check:dependency-policy": "node scripts/check-dependency-policy.mjs",
    "check:api-surface": "node scripts/check-api-surface.mjs",
    "check:adr-manifest": "node scripts/check-adr-manifest.mjs",
    "check:doc-orphans": "node scripts/check-doc-orphans.mjs",
    "check:readme-exports": "node scripts/check-readme-exports.mjs",
    "check:config-docs": "vitest run tests/docs/config-docs-alignment.test.ts",
    "check:adapter-docs": "node scripts/sync-adapter-docs.mjs --check",
    "sync:adapter-docs": "node scripts/sync-adapter-docs.mjs",
    "check:stable": "node scripts/run-stable-smoke.mjs",
    "check:l4": "node scripts/run-l4-check.mjs",
    "check:rich-segments": "node scripts/check-rich-segment-adapters.mjs",
    "check:ai-outbound": "node scripts/check-ai-outbound-adapters.mjs",
    "check:interactive-segments": "node scripts/check-interactive-segment-adapters.mjs",
    "check:segments": "node scripts/check-segment-adapters.mjs",
    "check:use-plugin-top-level": "node scripts/check-use-plugin-top-level.mjs",
    "check:get-plugin-runtime": "node scripts/check-get-plugin-runtime.mjs",
    "check:all": "node scripts/check-all-harness.mjs",
    "type-check": "tsc --noEmit -p tsconfig.typecheck.json",
    "link": "pnpm --filter @zhin.js/cli exec npm link",
    "test": "vitest run",
    "test:reporter": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "create": "node packages/toolkit/create-zhin/lib/index.js",
    "docs:dev": "pnpm --filter @zhin.js/docs dev",
    "docs:build": "pnpm docs:api && pnpm sync:adapter-docs && pnpm --filter @zhin.js/docs build",
    "docs:preview": "pnpm --filter @zhin.js/docs preview",
    "docs:api": "typedoc",
    "check:prod": "node scripts/check-production-config.js",
    "check:plugin": "node scripts/check-plugin-spec.mjs",
    "check:install-size": "node scripts/check-install-size.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.4",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "cross-spawn": "^7.0.6",
    "eslint": "^10.5.0",
    "fs-extra": "^11.3.5",
    "inquirer": "^14.0.2",
    "ora": "^9.4.1",
    "rimraf": "^6.1.3",
    "turbo": "^2.10.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.9",
    "zhin.js": "workspace:*"
  },
  "pnpm": {
    "overrides": {
      "@discordjs/rest>undici": "^6.27.0",
      "discord.js>undici": "^6.27.0",
      "utf7>semver": "^5.7.2",
      "hono": "^4.12.25",
      "nodemailer": "^9.0.1",
      "qs": "^6.15.2",
      "tar": "^7.5.16",
      "ip-address": "^10.1.1",
      "dompurify": "^3.4.11",
      "read-yaml-file>js-yaml": "^4.2.0",
      "tsup>esbuild": "^0.28.1",
      "bundle-require>esbuild": "^0.28.1",
      "vite": "^6.4.3",
      "brace-expansion": "^5.0.6",
      "vitest>vite": "^6.4.3",
      "@vitest/mocker>vite": "^6.4.3"
    }
  }
}
