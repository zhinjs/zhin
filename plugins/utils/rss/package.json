{
  "name": "@zhin.js/plugin-rss",
  "version": "0.0.6",
  "description": "RSS/Atom feed subscription & push plugin for Zhin.js — subscribe feeds, auto-poll, push new items to groups",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "development": "./src/index.ts",
      "import": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "client",
    "dist",
    "skills",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "rimraf lib"
  },
  "keywords": [
    "zhin",
    "zhin.js",
    "bot",
    "plugin",
    "rss",
    "atom",
    "feed",
    "subscription",
    "push",
    "notify",
    "chatbot",
    "im"
  ],
  "author": {
    "name": "lc-cn",
    "email": "admin@liucl.cn",
    "url": "https://github.com/lc-cn"
  },
  "license": "MIT",
  "dependencies": {
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "typescript": "^6.0.0",
    "zhin.js": "workspace:*"
  },
  "peerDependencies": {
    "zhin.js": ">=1.0.66"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhinjs/zhin.git",
    "directory": "plugins/utils/rss"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
