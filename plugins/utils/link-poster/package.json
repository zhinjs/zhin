{
  "name": "@zhin.js/plugin-link-poster",
  "version": "3.0.3",
  "description": "Auto-detect link posters for Zhin.js (Plugin Runtime)",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "development": "./src/index.ts",
      "import": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "plugin.ts",
    "schema.json",
    "middlewares",
    "src",
    "lib",
    "agent",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf lib",
    "test": "NODE_OPTIONS=--experimental-strip-types vitest run --root ../../.. plugins/utils/link-poster/tests",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "zhin",
    "zhin.js",
    "bot",
    "plugin",
    "link-poster",
    "bilibili",
    "github",
    "douyin",
    "xiaohongshu"
  ],
  "author": {
    "name": "lc-cn",
    "email": "admin@liucl.cn",
    "url": "https://github.com/lc-cn"
  },
  "license": "MIT",
  "dependencies": {
    "@zhin.js/core": "workspace:*",
    "@zhin.js/html-renderer": "workspace:*",
    "@zhin.js/middleware": "workspace:*",
    "@zhin.js/plugin-runtime": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhinjs/zhin.git",
    "directory": "plugins/utils/link-poster"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "zhin": {
    "protocol": 1,
    "type": "plugin",
    "entry": "./plugin.ts",
    "engine": "^1.0.0",
    "runtime": "trusted",
    "features": [
      {
        "package": "@zhin.js/middleware",
        "api": "^1.0.0"
      }
    ],
    "plugins": []
  }
}
