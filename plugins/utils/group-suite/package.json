    "lib",
    "skills",
    "tools",
    "plugin.yml",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "rimraf lib"
  },
  "keywords": [
    "zhin",
    "zhin.js",
    "bot",
    "plugin",
    "group",
    "checkin",
    "stats",
    "teach",
    "welcome"
  ],
  "author": {
    "name": "lc-cn",
    "email": "admin@liucl.cn",
    "url": "https://github.com/lc-cn"
  },
  "license": "MIT",
  "dependencies": {
    "@zhin.js/satori": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "zhin.js": "workspace:*",
    "@zhin.js/plugin-html-renderer": "workspace:*"
  },
  "peerDependencies": {
    "zhin.js": "workspace:*",
    "@zhin.js/plugin-html-renderer": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@zhin.js/plugin-html-renderer": {
      "optional": true
    }
  },
  "repository": {
