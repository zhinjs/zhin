{
  "name": "@zhin.js/plugin-60s",
  "version": "3.0.2",
  "description": "60s API aggregation plugin for Zhin.js — news, weather, hot searches, utilities and more",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "development": "./src/index.ts",
      "import": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "agent",
    "tools",
    "plugin.yml",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf lib",
    "test": "sh -c 'cd ../../.. && vitest run plugins/utils/60s/tests'",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "zhin",
    "zhin.js",
    "bot",
    "plugin",
    "60s",
    "news",
    "weather",
    "weibo",
    "zhihu",
    "douyin",
    "hot-search",
    "hitokoto",
    "api",
    "chatbot"
  ],
  "author": {
    "name": "lc-cn",
    "email": "admin@liucl.cn",
    "url": "https://github.com/lc-cn"
  },
  "license": "MIT",
  "devDependencies": {
    "typescript": "^6.0.3",
    "zhin.js": "workspace:*",
    "@zhin.js/agent": "workspace:*",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "zhin.js": "workspace:*",
    "@zhin.js/agent": "workspace:*",
    "zod": "^4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhinjs/zhin.git",
    "directory": "plugins/utils/60s"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "peerDependenciesMeta": {
    "@zhin.js/agent": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  }
}
