{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "pickCount": { "type": "number", "default": 5, "minimum": 1, "maximum": 10 },
    "scheduleCron": { "type": "string", "default": "0 0 18 * * *" },
    "historyLimit": { "type": "number", "default": 500, "minimum": 50, "maximum": 2000 },
    "scheduleEnabled": { "type": "boolean", "default": true },
    "agentEnabled": { "type": "boolean", "default": true },
    "backtestEnabled": { "type": "boolean", "default": true },
    "backtestWindow": { "type": "number", "default": 50 },
    "backtestRandomTrials": { "type": "number", "default": 64 },
    "backtestMinHistory": { "type": "number", "default": 30 },
    "backtestAdaptive": { "type": "boolean", "default": true },
    "weightPersistEnabled": { "type": "boolean", "default": true },
    "weightHoldoutFallback": { "type": "boolean", "default": true },
    "games": {
      "type": "array",
      "items": { "type": "string" },
      "default": ["kl8", "ssq", "dlt", "fc3d", "pl3", "pl5"]
    },
    "pushTargets": {
      "type": "array",
      "description": "OutboundHost push destinations for cron/publish reports",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["adapter", "channelId"],
        "properties": {
          "adapter": { "type": "string" },
          "endpointId": { "type": "string" },
          "channelType": { "type": "string", "default": "private" },
          "channelId": { "type": "string" }
        }
      },
      "default": []
    },
    "kl8": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pickCount": { "type": "number", "default": 5 },
        "recommendGroups": { "type": "number", "default": 3 },
        "groupStrategies": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["balanced", "hot", "cold"]
        }
      }
    }
  }
}
