{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Zhin Console — 适配器 / 插件「浏览器端 client/」推荐基线",
  "compilerOptions": {
    "baseUrl": ".",
    "declaration": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true
  }
}
