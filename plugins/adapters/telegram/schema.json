{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "polling": {
      "type": "boolean",
      "default": true,
      "description": "Long-poll getUpdates (default). Set false for webhook via httpHostToken."
    },
    "webhook": {
      "type": "object",
      "additionalProperties": false,
      "description": "Webhook settings when polling is false.",
      "properties": {
        "domain": {
          "type": "string"
        },
        "path": {
          "type": "string",
          "default": "/telegram/webhook"
        },
        "secretToken": {
          "type": "string",
          "description": "Verified via X-Telegram-Bot-Api-Secret-Token."
        }
      }
    },
    "allowedUpdates": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [
        "message",
        "callback_query"
      ]
    },
    "apiBaseUrl": {
      "type": "string",
      "default": "https://api.telegram.org"
    },
    "endpoints": {
      "type": "array",
      "description": "多账号：一个插件实例挂多个 endpoint。每项与顶层字段同构（name 必填，其余覆盖顶层）",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "description": "Telegram bot name"
          },
          "token": {
            "type": "string",
            "description": "Telegram bot token"
          }
        },
        "required": [
          "name",
          "token"
        ]
      }
    },
    "commandPrefix": {
      "type": "string",
      "default": "",
      "description": "命令前缀（默认 '' 无前缀，任意文本按命令匹配；如 '/' 要求 / 开头）。endpoints[i] 可逐项覆盖"
    }
  },
  "required": [
    "endpoints"
  ]
}
