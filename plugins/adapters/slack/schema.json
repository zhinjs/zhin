{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "socketMode": {
      "type": "boolean",
      "default": true,
      "description": "Prefer Socket Mode (default). Set false for HTTP Events via httpHostToken."
    },
    "webhookPath": {
      "type": "string",
      "default": "/slack/events"
    },
    "clientPingTimeout": {
      "type": "number",
      "default": 15000,
      "description": "Socket Mode client ping timeout (ms)"
    },
    "endpoints": {
      "type": "array",
      "description": "多账号：一个插件实例挂多个 endpoint。每项与顶层字段同构（name 必填，其余覆盖顶层）",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "description": "Slack bot name"
          },
          "token": {
            "type": "string",
            "description": "Bot User OAuth Token (xoxb-...)"
          },
          "signingSecret": {
            "type": "string",
            "description": "Required for HTTP Events API (socketMode: false)"
          },
          "appToken": {
            "type": "string",
            "description": "App-Level Token (xapp-...) for Socket Mode"
          }
        },
        "required": [
          "name",
          "token"
        ]
      }
    },
    "commandPrefix": {
      "type": "string",
      "default": "",
      "description": "命令前缀（默认 '' 无前缀，任意文本按命令匹配；如 '/' 要求 / 开头）。endpoints[i] 可逐项覆盖"
    }
  },
  "required": [
    "endpoints"
  ]
}
