{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "connection": {
      "type": "string",
      "enum": [
        "gateway",
        "interactions"
      ],
      "default": "gateway",
      "description": "Gateway WebSocket (default). interactions uses httpHostToken POST + Ed25519 verify."
    },
    "intents": {
      "type": "array",
      "items": {
        "type": "number"
      }
    },
    "enableSlashCommands": {
      "type": "boolean",
      "default": false
    },
    "globalCommands": {
      "type": "boolean",
      "default": false
    },
    "defaultActivity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "PLAYING",
            "STREAMING",
            "LISTENING",
            "WATCHING",
            "COMPETING"
          ]
        },
        "url": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "type"
      ]
    },
    "slashCommands": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "applicationId": {
      "type": "string",
      "description": "Required when connection is interactions."
    },
    "publicKey": {
      "type": "string",
      "description": "Required when connection is interactions (hex Ed25519 public key)."
    },
    "interactionsPath": {
      "type": "string",
      "default": "/discord/interactions",
      "description": "POST path on httpHostToken when connection is interactions."
    },
    "endpoints": {
      "type": "array",
      "description": "多账号：一个插件实例挂多个 endpoint。每项与顶层字段同构（name 必填，其余覆盖顶层）",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "description": "Discord bot name"
          },
          "token": {
            "type": "string",
            "description": "Discord bot token"
          }
        },
        "required": [
          "name",
          "token"
        ]
      }
    },
    "commandPrefix": {
      "type": "string",
      "default": "",
      "description": "命令前缀（默认 '' 无前缀，任意文本按命令匹配；如 '/' 要求 / 开头）。endpoints[i] 可逐项覆盖"
    }
  },
  "required": [
    "endpoints"
  ]
}
