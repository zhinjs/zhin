    "url": "git+https://github.com/zhinjs/zhin.git",
    "type": "git",
    "directory": "plugins/adapters/napcat"
  },
  "dependencies": {
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@zhin.js/cli": "workspace:*",
    "@types/node": "^25.6.0",
