{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "default": "email-bot"
    },
    "smtp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "number" },
        "secure": { "type": "boolean" },
        "auth": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "user": { "type": "string" },
            "pass": { "type": "string" }
          },
          "required": ["user", "pass"]
        }
      },
      "required": ["host", "port", "secure", "auth"]
    },
    "imap": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "number" },
        "tls": { "type": "boolean" },
        "user": { "type": "string" },
        "password": { "type": "string" },
        "checkInterval": { "type": "number", "default": 60000 },
        "mailbox": { "type": "string", "default": "INBOX" },
        "markSeen": { "type": "boolean", "default": true }
      },
      "required": ["host", "port", "tls", "user", "password"]
    },
    "attachments": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "downloadPath": { "type": "string" },
        "maxFileSize": { "type": "number" },
        "allowedTypes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
