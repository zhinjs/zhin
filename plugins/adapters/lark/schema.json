{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "default": "lark-bot"
    },
    "appId": {
      "type": "string"
    },
    "appSecret": {
      "type": "string"
    },
    "encryptKey": {
      "type": "string"
    },
    "verificationToken": {
      "type": "string"
    },
    "webhookPath": {
      "type": "string",
      "default": "/lark/webhook"
    },
    "apiBaseUrl": {
      "type": "string"
    },
    "isFeishu": {
      "type": "boolean",
      "default": true
    },
    "commandPrefix": {
      "type": "string",
      "default": "",
      "description": "命令前缀（默认 '' 无前缀，任意文本按命令匹配；如 '/' 要求 / 开头）。endpoints[i] 可逐项覆盖"
    }
  },
  "required": [
    "appId",
    "appSecret"
  ]
}
