{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "connection": {
      "type": "string",
      "enum": [
        "ws",
        "sse",
        "webhook",
        "wss"
      ],
      "default": "ws",
      "description": "ws (default), sse (EventSource client), webhook or wss (webhook/wss via httpHostToken)"
    },
    "reconnect_interval": {
      "type": "number",
      "default": 5000
    },
    "heartbeat_interval": {
      "type": "number",
      "default": 30000
    },
    "endpoints": {
      "type": "array",
      "description": "多账号：一个插件实例挂多个 endpoint。每项与顶层字段同构（name 必填，其余覆盖顶层）",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "description": "Milky bot name"
          },
          "baseUrl": {
            "type": "string",
            "description": "Milky HTTP API base URL (required); WS event path is derived as ws(s)://host/event"
          },
          "path": {
            "type": "string",
            "description": "Path for webhook / reverse-wss"
          },
          "access_token": {
            "type": "string",
            "description": "Milky access token"
          }
        },
        "required": [
          "name",
          "baseUrl"
        ]
      }
    },
    "commandPrefix": {
      "type": "string",
      "default": "",
      "description": "命令前缀（默认 '' 无前缀，任意文本按命令匹配；如 '/' 要求 / 开头）。endpoints[i] 可逐项覆盖"
    }
  },
  "required": [
    "endpoints"
  ]
}
