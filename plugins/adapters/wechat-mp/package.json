{
  "name": "@zhin.js/adapter-wechat-mp",
  "version": "4.0.0",
  "type": "module",
  "description": "Zhin.js WeChat Official Account adapter for Plugin Runtime (HTTP webhook)",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rimraf lib",
    "test": "NODE_OPTIONS=--experimental-strip-types vitest run --root ../../.. plugins/adapters/wechat-mp/tests",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@zhin.js/adapter": "workspace:*",
    "@zhin.js/core": "workspace:*",
    "@zhin.js/host-http": "workspace:*",
    "@zhin.js/logger": "workspace:*",
    "@zhin.js/plugin-runtime": "workspace:*",
    "axios": "^1.18.0",
    "xml2js": "^0.6.2"
  },
  "peerDependencies": {
    "@zhin.js/adapter": "workspace:*",
    "@zhin.js/core": "workspace:*",
    "@zhin.js/host-http": "workspace:*",
    "@zhin.js/plugin-runtime": "workspace:*",
    "zhin.js": "workspace:*"
  },
  "peerDependenciesMeta": {
    "zhin.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/xml2js": "^0.4.14",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "zhin",
    "zhin.js",
    "bot",
    "adapter",
    "wechat",
    "weixin",
    "微信",
    "official-account",
    "mp",
    "chatbot"
  ],
  "author": {
    "name": "lc-cn",
    "email": "admin@liucl.cn",
    "url": "https://github.com/lc-cn"
  },
  "license": "MIT",
  "repository": {
    "url": "git+https://github.com/zhinjs/zhin.git",
    "type": "git",
    "directory": "plugins/adapters/wechat-mp"
  },
  "files": [
    "adapters",
    "plugin.ts",
    "schema.json",
    "src",
    "lib",
    "agent",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "development": "./src/index.ts",
      "import": "./lib/index.js"
    }
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "zhin": {
    "protocol": 1,
    "type": "plugin",
    "entry": "./plugin.ts",
    "engine": "^1.0.0",
    "runtime": "trusted",
    "features": [
      {
        "package": "@zhin.js/adapter",
        "api": "^1.0.0"
      }
    ],
    "plugins": []
  }
}
