{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "path": {
      "type": "string",
      "default": "/wechat/webhook"
    },
    "encrypt": {
      "type": "boolean",
      "default": false
    },
    "encryptMode": {
      "type": "string",
      "enum": [
        "plain",
        "compatible",
        "secure"
      ],
      "description": "Default follows encrypt: 'plain' when encrypt=false, 'compatible' when encrypt=true"
    },
    "replyMode": {
      "type": "string",
      "enum": [
        "passive",
        "customer_service"
      ],
      "default": "passive"
    },
    "passiveReplyTimeoutMs": {
      "type": "number",
      "default": 4500
    },
    "endpoints": {
      "type": "array",
      "description": "多账号：一个插件实例挂多个 endpoint。每项与顶层字段同构（name 必填，其余覆盖顶层）",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "description": "WeChat MP bot name"
          },
          "appId": {
            "type": "string",
            "description": "WeChat MP app ID"
          },
          "appSecret": {
            "type": "string",
            "description": "WeChat MP app secret"
          },
          "token": {
            "type": "string",
            "description": "WeChat MP callback token"
          },
          "encodingAESKey": {
            "type": "string",
            "description": "WeChat MP encoding AES key"
          }
        },
        "required": [
          "name",
          "appId",
          "appSecret",
          "token"
        ]
      }
    },
    "commandPrefix": {
      "type": "string",
      "default": "",
      "description": "命令前缀（默认 '' 无前缀，任意文本按命令匹配；如 '/' 要求 / 开头）。endpoints[i] 可逐项覆盖"
    }
  },
  "required": [
    "endpoints"
  ]
}
