{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "botAgent": {
      "type": "string"
    },
    "baseUrl": {
      "type": "string",
      "default": "https://ilinkai.weixin.qq.com"
    },
    "cdnBaseUrl": {
      "type": "string",
      "default": "https://novac2c.cdn.weixin.qq.com/c2c"
    },
    "longPollTimeoutMs": {
      "type": "number",
      "default": 35000
    },
    "endpoints": {
      "type": "array",
      "description": "多账号：一个插件实例挂多个 endpoint。每项与顶层字段同构（name 必填，其余覆盖顶层）",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "description": "Weixin iLink bot name"
          },
          "botToken": {
            "type": "string",
            "description": "iLink bot token (prefer env WEIXIN_ILINK_TOKEN or sidecar credential file)"
          }
        },
        "required": [
          "name",
          "botToken"
        ]
      }
    },
    "commandPrefix": {
      "type": "string",
      "default": "",
      "description": "命令前缀（默认 '' 无前缀，任意文本按命令匹配；如 '/' 要求 / 开头）。endpoints[i] 可逐项覆盖"
    }
  },
  "required": [
    "endpoints"
  ]
}
