{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "default": "qq-bot"
    },
    "appid": {
      "type": "string"
    },
    "secret": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": ["websocket", "webhook", "middleware"],
      "default": "websocket",
      "description": "WebSocket gateway (default). webhook/middleware use httpHostToken POST."
    },
    "sandbox": {
      "type": "boolean",
      "default": false
    },
    "intents": {
      "type": "array",
      "items": { "type": "string" }
    },
    "accessTokenUrl": {
      "type": "string"
    },
    "gatewayUrl": {
      "type": "string"
    },
    "endpoints": {
      "type": "array",
      "description": "多账号：一个插件实例挂多个 endpoint；每项以实例配置为基础逐项覆盖，name 必填",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" }
        },
        "required": ["name"],
        "additionalProperties": true
      }
    },
    "webhookPath": {
      "type": "string",
      "default": "/qq/webhook",
      "description": "POST path on httpHostToken for webhook/middleware modes."
    },
    "port": {
      "type": "number",
      "description": "Legacy standalone webhook port (unused with httpHostToken)."
    },
    "path": {
      "type": "string",
      "description": "Legacy standalone webhook path (unused with httpHostToken)."
    }
  },
  "anyOf": [
    {
      "properties": {
        "appid": { "type": "string", "minLength": 1 },
        "secret": { "type": "string", "minLength": 1 }
      },
      "required": ["appid", "secret"]
    },
    { "properties": { "endpoints": { "type": "array", "minItems": 1 } }, "required": ["endpoints"] }
  ]
}
