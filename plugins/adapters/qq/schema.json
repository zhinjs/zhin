{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "mode": {
      "type": "string",
      "enum": [
        "websocket",
        "webhook",
        "middleware"
      ],
      "default": "websocket",
      "description": "WebSocket gateway (default). webhook/middleware use httpHostToken POST."
    },
    "sandbox": {
      "type": "boolean",
      "default": false
    },
    "master": {
      "type": ["string", "number"],
      "description": "Endpoint Owner（qq endpoint 管理命令权限、AI master 角色）；endpoints[i] 可逐项覆盖"
    },
    "intents": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "accessTokenUrl": {
      "type": "string"
    },
    "gatewayUrl": {
      "type": "string"
    },
    "webhookPath": {
      "type": "string",
      "default": "/qq/webhook",
      "description": "POST path on httpHostToken for webhook/middleware modes."
    },
    "port": {
      "type": "number",
      "description": "Legacy standalone webhook port (unused with httpHostToken)."
    },
    "path": {
      "type": "string",
      "description": "Legacy standalone webhook path (unused with httpHostToken)."
    },
    "endpoints": {
      "type": "array",
      "description": "多账号：一个插件实例挂多个 endpoint。每项与顶层字段同构（name 必填，其余覆盖顶层）",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "description": "QQ bot name"
          },
          "appid": {
            "type": "string",
            "description": "QQ official bot app ID"
          },
          "secret": {
            "type": "string",
            "description": "QQ official bot secret"
          }
        },
        "required": [
          "name",
          "appid",
          "secret"
        ]
      }
    },
    "commandPrefix": {
      "type": "string",
      "default": "",
      "description": "命令前缀（默认 '' 无前缀，任意文本按命令匹配；如 '/' 要求 / 开头）。endpoints[i] 可逐项覆盖"
    }
  },
  "required": [
    "endpoints"
  ]
}
