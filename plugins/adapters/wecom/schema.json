{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "default": "wecom-bot"
    },
    "corpId": {
      "type": "string"
    },
    "agentSecret": {
      "type": "string"
    },
    "token": {
      "type": "string"
    },
    "encodingAESKey": {
      "type": "string"
    },
    "webhookPath": {
      "type": "string",
      "default": "/wecom/callback"
    },
    "apiBaseUrl": {
      "type": "string",
      "default": "https://qyapi.weixin.qq.com"
    },
    "commandPrefix": {
      "type": "string",
      "default": "",
      "description": "命令前缀（默认 '' 无前缀，任意文本按命令匹配；如 '/' 要求 / 开头）。endpoints[i] 可逐项覆盖"
    }
  },
  "required": [
    "corpId",
    "agentSecret",
    "token",
    "encodingAESKey"
  ]
}
