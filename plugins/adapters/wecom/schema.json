{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "webhookPath": {
      "type": "string",
      "default": "/wecom/callback"
    },
    "apiBaseUrl": {
      "type": "string",
      "default": "https://qyapi.weixin.qq.com"
    },
    "endpoints": {
      "type": "array",
      "description": "多账号：一个插件实例挂多个 endpoint。每项与顶层字段同构（name 必填，其余覆盖顶层）",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "description": "WeCom bot name"
          },
          "corpId": {
            "type": "string",
            "description": "WeCom corp ID"
          },
          "agentSecret": {
            "type": "string",
            "description": "WeCom agent secret"
          },
          "token": {
            "type": "string",
            "description": "WeCom callback token"
          },
          "encodingAESKey": {
            "type": "string",
            "description": "WeCom encoding AES key"
          }
        },
        "required": [
          "name",
          "corpId",
          "agentSecret",
          "token",
          "encodingAESKey"
        ]
      }
    },
    "commandPrefix": {
      "type": "string",
      "default": "",
      "description": "命令前缀（默认 '' 无前缀，任意文本按命令匹配；如 '/' 要求 / 开头）。endpoints[i] 可逐项覆盖"
    }
  },
  "required": [
    "endpoints"
  ]
}
