{
  "name": "@zhin.js/adapter-sandbox",
  "version": "5.0.5",
  "description": "Zhin.js Sandbox adapter for Plugin Runtime (WebSocket /sandbox)",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "development": "./src/index.ts",
      "import": "./lib/index.js"
    }
  },
  "files": [
    "adapters",
    "pages",
    "plugin.ts",
    "schema.json",
    "src",
    "lib",
    "dist",
    "agent",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "zhin",
    "zhin.js",
    "bot",
    "adapter",
    "sandbox",
    "test",
    "development",
    "local"
  ],
  "author": {
    "name": "lc-cn",
    "email": "admin@liucl.cn",
    "url": "https://github.com/lc-cn"
  },
  "license": "MIT",
  "repository": {
    "url": "git+https://github.com/zhinjs/zhin.git",
    "type": "git",
    "directory": "plugins/adapters/sandbox"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf lib",
    "test": "NODE_OPTIONS=--experimental-strip-types vitest run --root ../../.. plugins/adapters/sandbox/tests",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@zhin.js/adapter": "workspace:*",
    "@zhin.js/console-contract": "workspace:*",
    "@zhin.js/core": "workspace:*",
    "@zhin.js/host-http": "workspace:*",
    "@zhin.js/logger": "workspace:*",
    "@zhin.js/page": "workspace:*",
    "@zhin.js/plugin-runtime": "workspace:*",
    "react": "^19.1.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "@zhin.js/pagemanager": "workspace:*",
    "@zhin.js/runtime": "workspace:*",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "ws": "^8.21.0"
  },
  "peerDependencies": {
    "@zhin.js/adapter": "workspace:*",
    "@zhin.js/console-contract": "workspace:*",
    "@zhin.js/core": "workspace:*",
    "@zhin.js/host-http": "workspace:*",
    "@zhin.js/page": "workspace:*",
    "@zhin.js/plugin-runtime": "workspace:*",
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "zhin": {
    "protocol": 1,
    "type": "plugin",
    "entry": "./plugin.ts",
    "engine": "^1.0.0",
    "runtime": "trusted",
    "features": [
      {
        "package": "@zhin.js/adapter",
        "api": "^1.0.0"
      },
      {
        "package": "@zhin.js/page",
        "api": "^1.0.0"
      }
    ],
    "plugins": []
  }
}
